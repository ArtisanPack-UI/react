{
  "name": "@artisanpack-ui/tokens",
  "version": "2.0.0",
  "description": "Shared design tokens, color resolver, and glass helpers for ArtisanPack UI",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/tokens.css",
    "./tailwind": {
      "import": "./dist/tailwind-plugin.mjs",
      "types": "./dist/tailwind-plugin.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT"
}
