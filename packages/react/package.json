{
  "name": "@artisanpack-ui/react",
  "version": "0.0.0",
  "description": "80+ React UI components for the ArtisanPack UI ecosystem, styled with DaisyUI and Tailwind CSS",
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./form": {
      "import": "./dist/form.mjs",
      "types": "./dist/form.d.ts"
    },
    "./layout": {
      "import": "./dist/layout.mjs",
      "types": "./dist/layout.d.ts"
    },
    "./navigation": {
      "import": "./dist/navigation.mjs",
      "types": "./dist/navigation.d.ts"
    },
    "./display": {
      "import": "./dist/display.mjs",
      "types": "./dist/display.d.ts"
    },
    "./data": {
      "import": "./dist/data.mjs",
      "types": "./dist/data.d.ts"
    },
    "./chart": {
      "import": "./dist/chart.mjs",
      "types": "./dist/chart.d.ts"
    },
    "./feedback": {
      "import": "./dist/feedback.mjs",
      "types": "./dist/feedback.d.ts"
    },
    "./utility": {
      "import": "./dist/utility.mjs",
      "types": "./dist/utility.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@artisanpack-ui/tokens": "*"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "apexcharts": "~3.45.2",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-apexcharts": "1.5.0",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "apexcharts": "^3.41.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-apexcharts": "^1.5.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "apexcharts": { "optional": true },
    "react-apexcharts": { "optional": true }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "license": "MIT"
}
